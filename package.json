{
  "name": "locksmith",
  "version": "1.0.1",
  "description": "Security policy checker for Node/Bun projects using pnpm",
  "type": "module",
  "bin": {
    "locksmith": "./bin/cli.ts"
  },
  "scripts": {
    "dev": "bun run ./bin/cli.ts",
    "build": "bun build ./bin/cli.ts --outdir ./dist --target bun --minify",
    "build:mcp": "bun build ./bin/mcp.ts --compile --outfile ./dist/mcp --target bun",
    "test": "bun test",
    "lint": "bunx tsc --noEmit",
    "preinstall": "npx only-allow pnpm",
    "security": "locksmith .",
    "security:fix": "locksmith . --fix",
    "security:ci": "locksmith . --strict",
    "install:ci": "pnpm install --frozen-lockfile --ignore-scripts",
    "clean-mcp": "bun run scripts/clean-mcp.ts",
    "clean-mcp:dry": "bun run scripts/clean-mcp.ts --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "picocolors": "^1.1.1",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20.19.41",
    "@types/yargs": "^17.0.35",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.1.3"
}
